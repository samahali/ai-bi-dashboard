# =============================================================================
# AI-Powered BI Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="AI BI Dashboard"
APP_ENV=development          # development | production
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=bidashboard
POSTGRES_PASSWORD=bidashboard_secret
POSTGRES_DB=bi_dashboard
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://bidashboard:bidashboard_secret@postgres:5432/bi_dashboard

# =============================================================================
# VECTOR STORE (ChromaDB)
# =============================================================================
CHROMADB_HOST=chromadb
CHROMADB_PORT=8001

# =============================================================================
# IBM WATSONX (Primary LLM)
# =============================================================================
WATSONX_APIKEY=your_ibm_cloud_api_key_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# =============================================================================
# OPENAI (Fallback LLM)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo

# Default LLM provider: granite | openai
DEFAULT_LLM_PROVIDER=granite

# =============================================================================
# FILE STORAGE
# =============================================================================
UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=csv,xlsx,json

# =============================================================================
# REPORT STORAGE
# =============================================================================
REPORTS_DIR=/app/storage/reports

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# =============================================================================
# FRONTEND (Vite)
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME="AI BI Dashboard"
VITE_APP_ENV=development
